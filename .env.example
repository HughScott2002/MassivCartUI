# ── Supabase (safe to expose — anon key only) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# ── Mapbox ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.<mapbox-public-token>

# ── Backend ───────────────────────────────────────────────────────────────────
# Server-side only — Next.js → Express. Never exposed to the browser.
BACKEND_URL=http://app:8000        # Docker Compose
# BACKEND_URL=http://localhost:8000  # local dev (no Docker)

# ── Admin routes ──────────────────────────────────────────────────────────────
# Same value as PLACES_SYNC_SECRET in the backend .env.
# Used server-side only by /api/admin/* Next.js routes.
PLACES_SYNC_SECRET=<random-hex>

# ── Misc ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
